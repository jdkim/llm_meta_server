# llm_meta_server/.env.production — read by the systemd unit via
# EnvironmentFile=. Mode 0600. Gitignored (do not commit).
# Copy template: cp .env.production.example .env.production && chmod 0600 .env.production

RAILS_ENV=production
# meta-server uses env-based secrets, not Rails credentials. Generate
# once and keep it (rotate annually):
#   openssl rand -hex 64
SECRET_KEY_BASE=PASTE_64_BYTE_HEX_FROM_openssl_rand_hex_64_HERE
RAILS_LOG_TO_STDOUT=0

# Puma binds to this port; nginx upstream `hub_app` should point here.
PORT=5001
RAILS_MAX_THREADS=5
WEB_CONCURRENCY=2

# Postgres on the same host via Unix socket / peer auth.
DB_HOST=
DB_USER=pubann
DB_PASSWORD=
DB_NAME=llm_meta_server_production

# Required for KMS-encrypted LlmApiKey storage. Same KMS_KEY_ID as dev
# so dev-encrypted ciphertexts migrate cleanly; consider a dedicated
# IAM user for prod credentials at some point.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
KMS_KEY_ID=

# Google OAuth for the web UI. ALLOWED_GOOGLE_CLIENT_IDS gates API
# access from the chat service (must include the chat service's
# client_id, comma-separated if multiple).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ALLOWED_GOOGLE_CLIENT_IDS=

# Public base URL of this hub. Reserved for future use (absolute-URL
# generation, etc.). Documenting it here keeps the env contract
# self-describing even though no code reads it today.
APP_HOST=https://hub.aibranch.org

# Ollama reachable from this host. Same values as dev — Ollama runs
# locally; defaults inside llm.rb are 127.0.0.1:11434 if unset.
OLLAMA_HOST=
OLLAMA_PORT=

# Comma-separated emails. Users with one of these emails get access
# to the /admin dashboard. Same allowlist should live in the chat
# service's .env.production so super-user status is consistent.
SUPER_USER_EMAILS=jindong.kim@gmail.com
