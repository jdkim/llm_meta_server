<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Signing in…</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%= csrf_meta_tags %>
  <style>
    html, body { height: 100%; margin: 0; font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif; }
    body { display: flex; align-items: center; justify-content: center; background: #f9fafb; color: #374151; }
    .panel { text-align: center; }
    .spinner {
      width: 28px; height: 28px;
      border: 3px solid #e5e7eb;
      border-top-color: #2563eb;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      margin: 0 auto 12px;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    noscript { display: block; margin-top: 16px; }
  </style>
</head>
<body>
  <div class="panel">
    <div class="spinner"></div>
    <p>Signing you in to hub.AIbranch…</p>
    <noscript>
      JavaScript is required to complete sign-in automatically.
      <%= button_to "Continue to sign-in", user_google_oauth2_omniauth_authorize_path, method: :post %>
    </noscript>
  </div>

  <%# Auto-submits to the omniauth-google-oauth2 start endpoint with a
      proper CSRF token (omniauth-rails_csrf_protection rejects GET and
      requires a valid authenticity_token). %>
  <%= form_with url: user_google_oauth2_omniauth_authorize_path,
                method: :post,
                local: true,
                id: "sso-form",
                data: { turbo: false } do %>
  <% end %>
  <script>document.getElementById("sso-form").submit();</script>
</body>
</html>
