<% content_for :title, "Admin · hub.AIbranch" %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-6">
  <div class="flex justify-between items-center">
    <h2 class="text-2xl font-bold text-gray-900">Hub Admin Dashboard</h2>
    <span class="text-xs text-gray-500">Snapshot: <%= @stats[:generated_at] %></span>
  </div>

  <%# Top-line counters %>
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
    <% [
      [ "Users",           @stats.dig(:users, :total) ],
      [ "With API keys",   @stats.dig(:users, :with_api_keys) ],
      [ "API keys total",  @stats.dig(:llm_api_keys, :total) ],
      [ "MCP servers",     @stats.dig(:mcp, :servers_total) ]
    ].each do |label, value| %>
      <div class="bg-white shadow-sm border border-gray-200 rounded-md p-4">
        <div class="text-xs text-gray-500 uppercase tracking-wide"><%= label %></div>
        <div class="text-2xl font-semibold text-gray-900 mt-1"><%= value %></div>
      </div>
    <% end %>
  </div>

  <%# API keys by provider %>
  <div class="bg-white shadow-sm border border-gray-200 rounded-md p-4">
    <h3 class="text-sm font-semibold text-gray-700 mb-3">API keys by provider</h3>
    <table class="min-w-full text-sm">
      <thead class="text-left text-gray-500">
        <tr><th class="py-1 pr-4">Provider</th><th class="py-1">Count</th></tr>
      </thead>
      <tbody>
        <% @stats.dig(:llm_api_keys, :by_provider).sort_by { |_, n| -n }.each do |provider, n| %>
          <tr class="border-t border-gray-100">
            <td class="py-1 pr-4"><%= provider %></td>
            <td class="py-1"><%= n %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <%# MCP breakdown %>
  <div class="bg-white shadow-sm border border-gray-200 rounded-md p-4">
    <h3 class="text-sm font-semibold text-gray-700 mb-3">MCP servers + tools</h3>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm">
      <% [
        [ "Servers total",  @stats.dig(:mcp, :servers_total) ],
        [ "Public servers", @stats.dig(:mcp, :servers_public) ],
        [ "Active servers", @stats.dig(:mcp, :servers_active) ],
        [ "Tools total",    @stats.dig(:mcp, :tools_total) ],
        [ "Tools active",   @stats.dig(:mcp, :tools_active) ]
      ].each do |label, value| %>
        <div>
          <div class="text-xs text-gray-500"><%= label %></div>
          <div class="text-lg font-medium text-gray-900"><%= value %></div>
        </div>
      <% end %>
    </div>
  </div>

  <%# Top favorited models %>
  <div class="bg-white shadow-sm border border-gray-200 rounded-md p-4">
    <h3 class="text-sm font-semibold text-gray-700 mb-3">Top favorited models</h3>
    <% top = @stats.dig(:favorites, :top_favorited_models) %>
    <% if top.blank? %>
      <p class="text-sm text-gray-500">No favorites yet.</p>
    <% else %>
      <table class="min-w-full text-sm">
        <thead class="text-left text-gray-500">
          <tr><th class="py-1 pr-4">Model</th><th class="py-1">Users</th></tr>
        </thead>
        <tbody>
          <% top.each do |model, n| %>
            <tr class="border-t border-gray-100">
              <td class="py-1 pr-4"><code><%= model %></code></td>
              <td class="py-1"><%= n %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
  </div>

  <%# Recent signups %>
  <div class="bg-white shadow-sm border border-gray-200 rounded-md p-4">
    <h3 class="text-sm font-semibold text-gray-700 mb-3">
      Recent signups
      <span class="text-xs text-gray-500 font-normal">— <%= @stats.dig(:users, :recent_signups_7d) %> in the last 7 days</span>
    </h3>
    <table class="min-w-full text-sm">
      <thead class="text-left text-gray-500">
        <tr><th class="py-1 pr-4">Email</th><th class="py-1">Joined</th></tr>
      </thead>
      <tbody>
        <% @stats.dig(:users, :recent).each do |email, joined_at| %>
          <tr class="border-t border-gray-100">
            <td class="py-1 pr-4"><%= email %></td>
            <td class="py-1 text-gray-600"><%= joined_at.strftime("%Y-%m-%d %H:%M") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
