<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <% if user_signed_in? %>
    <div class="space-y-6">
      <!-- Profile Card -->
      <div class="bg-white shadow-md rounded-lg overflow-hidden">
        <div class="px-6 py-4 bg-gray-50 border-b border-gray-200 flex justify-between items-center">
          <h4 class="text-lg font-semibold text-gray-900">Profile</h4>
          <%#= link_to "Edit", edit_user_profile_path, class: "text-sm bg-blue-100 text-blue-700 px-3 py-1 rounded-md hover:bg-blue-200 transition-colors" %>
        </div>
        <div class="px-6 py-4 space-y-4">
          <div class="flex">
            <div class="w-1/3">
              <span class="font-medium text-gray-700">Email Address:</span>
            </div>
            <div class="w-2/3">
              <span class="text-gray-900"><%= @user.email %></span>
            </div>
          </div>
          <div class="flex">
            <div class="w-1/3">
              <span class="font-medium text-gray-700">Provider ID:</span>
            </div>
            <div class="w-2/3">
              <span class="text-gray-900"><%= @user.google_id %></span>
            </div>
          </div>
          <div class="flex">
            <div class="w-1/3">
              <span class="font-medium text-gray-700">Registration Date:</span>
            </div>
            <div class="w-2/3">
              <span class="text-gray-900"><%= @user.created_at.strftime("%B %d, %Y") %></span>
            </div>
          </div>
        </div>
      </div>
      <!-- API Key Management Card -->
      <div class="bg-white shadow-md rounded-lg overflow-hidden">
        <div class="px-6 py-4 bg-gray-50 border-b border-gray-200 flex justify-between items-center">
          <h4 class="text-lg font-semibold text-gray-900">LLM API Key Management</h4>
          <%= link_to "Manage API Keys", user_llm_api_keys_path(@user), class: "text-sm bg-yellow-100 text-yellow-700 px-3 py-1 rounded-md hover:bg-yellow-200 transition-colors" %>
        </div>
        <div class="px-6 py-4">
          <p class="text-gray-600 mb-4">Manage your LLM service API keys.</p>
          <div class="space-y-2">
            <% if @user.llm_api_keys&.any? %>
              <% @user.llm_api_keys.each do |api_key| %>
                <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg border">
                  <div>
                    <h6 class="font-medium text-gray-900 mb-1"><%= api_key.llm_type.upcase %></h6>
                    <small class="text-gray-500">Registered</small>
                  </div>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                    Configured
                  </span>
                </div>
              <% end %>
            <% else %>
              <div class="p-4 bg-gray-50 rounded-lg border border-dashed border-gray-300">
                <p class="text-gray-500 text-center mb-0">No API keys registered yet.</p>
              </div>
            <% end %>
          </div>
        </div>
      </div>
      <!-- MCP Server Management Card -->
      <div class="bg-white shadow-md rounded-lg overflow-hidden">
        <div class="px-6 py-4 bg-gray-50 border-b border-gray-200 flex justify-between items-center">
          <h4 class="text-lg font-semibold text-gray-900">MCP Server Management</h4>
          <%= link_to "Manage MCP Servers", user_mcp_servers_path(@user), class: "text-sm bg-yellow-100 text-yellow-700 px-3 py-1 rounded-md hover:bg-yellow-200 transition-colors" %>
        </div>
        <div class="px-6 py-4">
          <p class="text-gray-600 mb-4">Manage your MCP (Model Context Protocol) servers and tools.</p>
          <div class="space-y-2">
            <% if @user.mcp_servers&.any? %>
              <% @user.mcp_servers.each do |server| %>
                <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg border">
                  <div>
                    <h6 class="font-medium text-gray-900 mb-1"><%= server.name %></h6>
                    <small class="text-gray-500"><%= server.url %></small>
                  </div>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= server.active? ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800' %>">
                    <%= server.active? ? "Active" : "Inactive" %>
                  </span>
                </div>
              <% end %>
            <% else %>
              <div class="p-4 bg-gray-50 rounded-lg border border-dashed border-gray-300">
                <p class="text-gray-500 text-center mb-0">No MCP servers registered yet.</p>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>
