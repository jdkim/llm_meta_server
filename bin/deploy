#!/usr/bin/env bash
# Production deploy for hub.aibranch.org.
# Usage:
#   bin/deploy                      # pull, bundle, migrate, precompile, restart
#   bin/deploy --no-pull            # local changes only (skip git pull)
#   bin/deploy --skip-restart       # build everything but don't bounce the service
#
# Idempotent. Safe to re-run.

set -euo pipefail

cd "$(dirname "$0")/.."

PULL=true
RESTART=true
for arg in "$@"; do
  case "$arg" in
    --no-pull)      PULL=false ;;
    --skip-restart) RESTART=false ;;
    *) echo "unknown flag: $arg" >&2; exit 2 ;;
  esac
done

# RVM's loader references variables that trip `set -u`; relax briefly
# while sourcing it, then re-enable.
if [ -s "$HOME/.rvm/scripts/rvm" ]; then
  set +u
  source "$HOME/.rvm/scripts/rvm"
  # RVM's default alias may not match this repo's .ruby-version
  # (e.g. system default 3.2.2 vs repo 3.4.9). Switch explicitly so
  # `bundle install` resolves against the right Ruby.
  if [ -f .ruby-version ]; then
    rvm use "$(cat .ruby-version)" >/dev/null
  fi
  set -u
fi

# Load production env vars (SECRET_KEY_BASE, DATABASE_URL, AWS_*, …) so
# `bin/rails` commands below boot Rails in the same env the systemd
# service does. dotenv-rails IS loaded in production here, but sourcing
# explicitly also covers the SECRET_KEY_BASE that production.rb reads
# before dotenv kicks in.
if [ -f .env.production ]; then
  set -a
  source .env.production
  set +a
fi

if [ "$PULL" = true ]; then
  echo "==> git pull"
  git pull --ff-only
fi

echo "==> bundle install (deployment)"
bundle config set deployment "true"
bundle config set without "development test"
bundle install --quiet

echo "==> db:migrate (production)"
RAILS_ENV=production bin/rails db:migrate

echo "==> tailwindcss:build + assets:precompile"
RAILS_ENV=production bin/rails tailwindcss:build assets:precompile

if [ "$RESTART" = true ]; then
  echo "==> systemctl restart llm_meta_server"
  sudo systemctl restart llm_meta_server
  sleep 2
  systemctl is-active llm_meta_server
fi

echo "==> done."
